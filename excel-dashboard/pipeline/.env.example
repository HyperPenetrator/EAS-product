# Pipeline Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ── Antigravity / Google Cloud ──────────────────────────────────────
GEMINI_PROJECT_ID=your_google_cloud_project_id
GEMINI_MODEL=gemini-2.5-flash

# ── CData Connect AI (for Excel Online MCP) ─────────────────────────
# Sign up at: https://www.cdata.com/connect/ai/
CDATA_PAT=your_cdata_personal_access_token
CDATA_DATASOURCE=ExcelOnline
EXCEL_WORKBOOK_ID=your_excel_online_workbook_id

# ── Report Storage Paths ─────────────────────────────────────────────
REPORT_OUTPUT_PATH=reports/
CLEAN_DATA_PATH=data/clean_data.csv
LOG_DIR=logs/

# ── Notification (optional) ──────────────────────────────────────────
NOTIFY_EMAIL=your@email.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# ── Flask Backend (if running the dashboard) ─────────────────────────
DATABASE_URL=sqlite:///reports.db
SECRET_KEY=change-me-in-production
FLASK_ENV=development
